_stdin = sys.stdin.buffer
_stdout = sys.stdout.buffer


def _read_message():
    line = _stdin.readline()
    if not line:
        return None
    line = line.strip()
    if not line:
        return _read_message()
    if line.startswith(b"Content-Length:"):
        length = int(line.split(b":", 1)[1].strip())
        while _stdin.readline().strip():
            pass
        data = b""
        while len(data) < length:
            chunk = _stdin.read(length - len(data))
            if not chunk:
                break
            data += chunk
        return json.loads(data)
    return json.loads(line)


def _write_message(message):
    data = json.dumps(message, ensure_ascii=False).encode("utf-8")
    _stdout.write(data + b"\n")
    _stdout.flush()


class ProgressReporter:
    def __init__(self, token):
        self.token = token
        self.sequence = 0
        self.buffer = ""
        self.last_sent = time.monotonic()

    def __call__(self, text):
        if self.token is None:
            return
        self.buffer += str(text)
        now = time.monotonic()
        status = str(text).startswith(
            (
                "turn ",
                "tool:",
                "verification",
                "context compacted",
                "early stop",
                "waiting for oMLX",
            )
        )
        if len(self.buffer) >= 160 or status or now - self.last_sent >= 0.25:
            self.flush()

    def flush(self):
        if self.token is None or not self.buffer:
            return
        self.sequence += 1
        _write_message({
            "jsonrpc": "2.0",
            "method": "notifications/progress",
            "params": {
                "progressToken": self.token,
                "progress": self.sequence,
                "message": core.truncate_output(self.buffer, 1200),
            },
        })
        self.buffer = ""
        self.last_sent = time.monotonic()


def _handle(message):
    method = message.get("method")
    message_id = message.get("id")
    if message_id is None:
        return None

    if method == "initialize":
        result = {
            "protocolVersion": "2024-11-05",
            "capabilities": {"tools": {}},
            "serverInfo": {"name": "si-qwen", "version": "2.0.0"},
            "instructions": INSTRUCTIONS,
        }
    elif method == "tools/list":
        result = {"tools": TOOLS}
    elif method == "tools/call":
        params = message.get("params", {})
        name = params.get("name", "")
        arguments = params.get("arguments", {})
        token = (params.get("_meta") or {}).get("progressToken")
        reporter = ProgressReporter(token)
        handler = TOOL_DISPATCH.get(name)
        if handler is None:
            result = _err(f"Unknown tool: {name}")
        else:
            try:
                result = handler(arguments, progress=reporter)
            except Exception as error:
                result = _err(f"Internal error in {name}: {type(error).__name__}: {error}")
            finally:
                reporter.flush()
    elif method == "ping":
        result = {}
    else:
        return {
            "jsonrpc": "2.0",
            "id": message_id,
            "error": {"code": -32601, "message": f"Method not found: {method}"},
        }
    return {"jsonrpc": "2.0", "id": message_id, "result": result}


def main():
    signal.signal(signal.SIGINT, lambda *_args: sys.exit(0))
    _log("started (direct oMLX mode)")
    try:
        while True:
            message = _read_message()
            if message is None:
                break
            response = _handle(message)
            if response is not None:
                _write_message(response)
    except (BrokenPipeError, IOError):
        pass
    _log("stopped")


if __name__ == "__main__":
    main()
