def _ok(text):
    return {"content": [{"type": "text", "text": text}], "isError": False}


def _err(text):
    return {"content": [{"type": "text", "text": text}], "isError": True}


def _log(message):
    print(f"[si-qwen-mcp] {message}", file=sys.stderr, flush=True)


def _parse_agent_output(text):
    info = {}
    match = re.search(r"status=(\w+)\s+turns=(\d+)", text)
    if match:
        info["status"] = match.group(1)
        info["turns"] = int(match.group(2))
    match = re.search(r"exit_code:\s*(\d+)", text)
    if match:
        info["exit_code"] = int(match.group(1))
    if "验证 PASS" in text:
        info["verify"] = "PASS"
    elif "验证 FAIL" in text or "verify_failed" in text:
        info["verify"] = "FAIL"
    match = re.search(r"diff 规模\s+(\d+)\s+行", text)
    if match:
        info["diff_lines"] = int(match.group(1))
    if "⚠ DIFF" in text:
        info["tripwire"] = True
    return info


def _auto_log_progress(project, spec_file, result_text):
    stem = os.path.splitext(os.path.basename(spec_file))[0]
    tasks_dir = os.path.join(os.path.realpath(project), ".qwen-tasks")
    log_path = os.path.join(tasks_dir, f"{stem}.progress.log")
    info = _parse_agent_output(result_text)
    attempt = 1
    if os.path.isfile(log_path):
        with open(log_path, encoding="utf-8") as handle:
            attempt = sum(1 for line in handle if "attempt" in line) + 1

    timestamp = datetime.now(timezone.utc).strftime("%Y-%m-%dT%H:%M:%SZ")
    turns = info.get("turns", "?")
    diff = info.get("diff_lines", "?")
    status = info.get("status", "unknown")
    passed = info.get("verify") == "PASS" or (
        info.get("verify") is None and info.get("exit_code", 1) == 0
    )
    reasons = []
    if status in ("stuck", "early_stop", "max_turns", "verify_failed", "exception"):
        reasons.append(status)
    if info.get("tripwire"):
        reasons.append(f"diff {diff} over threshold")
    if info.get("verify") == "FAIL":
        reasons.append("verify failed")
    if not reasons:
        reasons.append(status)
    entry = (
        f"{timestamp} · attempt {attempt} · turns={turns} · diff={diff} · "
        f"{'PASS' if passed else 'FAIL'}: {'; '.join(reasons)}"
    )
    os.makedirs(tasks_dir, exist_ok=True)
    with open(log_path, "a", encoding="utf-8") as handle:
        handle.write(entry + "\n")
    _log(f"progress logged: {log_path}")
    return entry


def _run_dispatch(arguments, task, progress):
    project = arguments.get("project", "")
    if not project or not os.path.isdir(project):
        return _err(f"Project directory not found: {project}")
    if not task.strip():
        return _err("Task description is empty.")

    try:
        lock_token = core.acquire_process_lock(
            LOCKFILE,
            wait_timeout=600,
            progress=progress,
        )
    except TimeoutError as error:
        return _err(str(error))
    try:
        result = core.run_dispatch(
            project=os.path.realpath(project),
            task=task,
            allow=arguments.get("allow"),
            verify=arguments.get("verify"),
            max_diff_lines=arguments.get("max_diff_lines"),
            verify_retries=arguments.get("verify_retries", 2),
            progress=progress,
        )
    except Exception as error:
        return _err(f"Dispatch error: {type(error).__name__}: {error}")
    finally:
        core.release_process_lock(lock_token)

    text = core.format_dispatch_result(result)
    return {
        "content": [{"type": "text", "text": text}],
        "isError": result.get("status") != "done",
    }


def do_dispatch_task(arguments, progress=None):
    return _run_dispatch(arguments, arguments.get("task", ""), progress or (lambda _text: None))


def do_dispatch_spec(arguments, progress=None):
    project = arguments.get("project", "")
    spec_file = arguments.get("spec_file", "")
    if not os.path.isabs(spec_file):
        spec_file = os.path.join(project, spec_file)
    if not os.path.isfile(spec_file):
        return _err(f"Spec file not found: {spec_file}")
    with open(spec_file, encoding="utf-8") as handle:
        task = handle.read()
    result = _run_dispatch(arguments, task, progress or (lambda _text: None))
    try:
        text = result["content"][0]["text"]
        entry = _auto_log_progress(project, spec_file, text)
        result["content"][0]["text"] += f"\n\nprogress.log: {entry}"
    except Exception as error:
        _log(f"auto-log failed: {error}")
    return result


def do_check_backend(arguments, progress=None):
    del progress
    base = arguments.get("base_url") or core.DEFAULT_BASE
    try:
        models = core.check_backend(base)
        return _ok(f"Backend online: {base}\nModels: {', '.join(models)}")
    except Exception as error:
        return _err(f"Backend NOT reachable ({base}): {error}")


def do_task_history(arguments, progress=None):
    del progress
    project = arguments.get("project", "")
    if not project or not os.path.isdir(project):
        return _err(f"Project directory not found: {project}")
    spec_filter = arguments.get("spec")
    tasks_dir = os.path.join(os.path.realpath(project), ".qwen-tasks")
    if not os.path.isdir(tasks_dir):
        return _ok("No .qwen-tasks/ directory. No dispatch history yet.")

    logs = []
    for filename in sorted(os.listdir(tasks_dir)):
        if not filename.endswith(".progress.log"):
            continue
        if spec_filter and not filename.startswith(spec_filter):
            continue
        path = os.path.join(tasks_dir, filename)
        with open(path, encoding="utf-8") as handle:
            content = handle.read().strip()
        if content:
            logs.append(f"=== {filename} ===\n{content}")
    return _ok("\n\n".join(logs) if logs else "No progress logs found.")


